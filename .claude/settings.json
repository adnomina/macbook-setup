{
    "permissions": {
        "allow": [
            "Bash(* --version)",
            "Bash(* -v)",
            "Bash(* --help)",
            "Bash(* -h)",
            "Bash(ls)",
            "Bash(bat)",
            "Bash(rg)"
        ],
        "defaultMode": "default"
    },
    "hooks": {},
    "statusLine": {
        "type": "command",
        "command": "~/.claude/statusline.sh"
    },
    "enabledPlugins": {
        "figma@claude-plugins-official": true
    },
    "extraKnownMarketplaces": {},
    "voiceEnabled": true,
    "preferredNotifChannel": "ghostty",
    "autoCompactEnabled": false
}
