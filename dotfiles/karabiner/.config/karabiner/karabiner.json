{
    "global": {
        "ask_for_confirmation_before_quitting": true,
        "check_for_updates_on_startup": true,
        "show_in_menu_bar": true,
        "show_profile_name_in_menu_bar": false,
        "unsafe_ui": false
    },
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Linux-style shortcuts: ctrl+[a/c/v/x/z/y/s/w/q/t/n/f/p/r/l] → cmd equivalent",
                        "manipulators": [
                            {
                                "description": "ctrl+a → cmd+a (select all)",
                                "from": { "key_code": "a", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "a", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+c → cmd+c (copy)",
                                "from": { "key_code": "c", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "c", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+v → cmd+v (paste)",
                                "from": { "key_code": "v", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "v", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+x → cmd+x (cut)",
                                "from": { "key_code": "x", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "x", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+z → cmd+z (undo)",
                                "from": { "key_code": "z", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "z", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+y → cmd+shift+z (redo)",
                                "from": { "key_code": "y", "modifiers": { "mandatory": ["left_control"] } },
                                "to": [{ "key_code": "z", "modifiers": ["left_command", "left_shift"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+s → cmd+s (save)",
                                "from": { "key_code": "s", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "s", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+w → cmd+w (close tab/window)",
                                "from": { "key_code": "w", "modifiers": { "mandatory": ["left_control"] } },
