                                "type": "basic"
                            },
                            {
                                "description": "ctrl+plus → cmd+plus (zoom in)",
                                "from": { "key_code": "equal_sign", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "equal_sign", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+minus → cmd+minus (zoom out)",
                                "from": { "key_code": "hyphen", "modifiers": { "mandatory": ["left_control"] } },
                                "to": [{ "key_code": "hyphen", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+0 → cmd+0 (reset zoom)",
                                "from": { "key_code": "0", "modifiers": { "mandatory": ["left_control"] } },
                                "to": [{ "key_code": "0", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+backslash → cmd+backslash (toggle sidebar)",
                                "from": { "key_code": "backslash", "modifiers": { "mandatory": ["left_control"] } },
                                "to": [{ "key_code": "backslash", "modifiers": ["left_command"] }],
                                "type": "basic"
                            }
                        ]
                    }
                ]
            },
            "name": "Default profile",
            "selected": true,
            "virtual_hid_keyboard": {
                "keyboard_type_v2": "ansi"
            }
        }
    ]
}
