                            },
                            {
                                "description": "ctrl+p → cmd+p (print/command palette)",
                                "from": { "key_code": "p", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "p", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+r → cmd+r (reload/run)",
                                "from": { "key_code": "r", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "r", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+l → cmd+l (address bar / go to line)",
                                "from": { "key_code": "l", "modifiers": { "mandatory": ["left_control"] } },
                                "to": [{ "key_code": "l", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+o → cmd+o (open)",
