                                "to": [{ "key_code": "q", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+t → cmd+t (new tab)",
                                "from": { "key_code": "t", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "t", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+n → cmd+n (new window/file)",
                                "from": { "key_code": "n", "modifiers": { "mandatory": ["left_control"], "optional": ["shift"] } },
                                "to": [{ "key_code": "n", "modifiers": ["left_command"] }],
                                "type": "basic"
                            },
                            {
                                "description": "ctrl+f → cmd+f (find)",
